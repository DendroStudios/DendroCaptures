{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DendroCapture",
  "version": "0.1.20",
  "identifier": "com.dendrostudios.capture",
  "build": {
    "beforeDevCommand": "npm run typecheck && npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run typecheck && npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DendroCapture",
        "width": 960,
        "height": 620,
        "minWidth": 740,
        "minHeight": 500,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
